{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "declaration": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "noUncheckedIndexedAccess": true,
    "baseUrl": ".",
    "paths": {
      "vn-address-kit": [
        "./src/index.ts"
      ]
    }
  },
  "include": [
    "src",
    "tests",
    "examples",
    "tsup.config.ts",
    "vitest.config.ts",
    "playground"
  ]
}
